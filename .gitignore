# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# docs and assets not for repo
*.zip
*.docx
/APP_SHELL_IMPLEMENTATION.md
/INFORME-HOSTING.md
/PROJECT_CONTEXT.md
/cropped-Projectx-300x300.png
/titulo-project.png
/logo.png

# claude code
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts

# capacitor native build artifacts
ios/App/Pods/
ios/App/App/public/
ios/App/output/
android/app/build/
android/.gradle/
android/capacitor-cordova-android-plugins/build/

# supabase cli transient cache
supabase/.temp/

# android signing — NEVER commit
android/local.properties
android/keystore.properties
*.jks
*.keystore

# transient Play Store assets (AAB + screenshots used for upload via JS bypass)
public/playstore-bundle.aab
public/playstore-feature.png
public/playstore-phone-*.png

# Forensic evidence exports — never commit
evidence/
